# Google Cloud Configuration
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_PROJECT_NUMBER=123456789012

# FactSet Application Configuration (MCP)
CLIENT_ID=your-factset-client-id
CLIENT_SECRET=your-factset-client-secret
AUTH_URI="https://auth.factset.com/as/authorization.oauth2"
SCOPES="scope=mcp"
TOKEN_URI="https://auth.factset.com/as/token.oauth2"
WELL_KNOWN_URI="https://auth.factset.com/.well-known/openid-configuration"

# Vertex AI Agent Architecture (Customer Defined)
GEMINI_ENTERPRISE_APP_ID=agentspace_xxxxxx
MODEL=gemini-2.5-flash
AGENT_SERVICE_NAME=factset-native-agent
AGENT_AUTH_ID=factset-oauth-native-v1
AGENT_DISPLAY_NAME="FactSet Agent v7"
